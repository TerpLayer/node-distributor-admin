# ============================================
# 节点商城管理后台 — 环境变量配置
# ============================================
# 复制本文件为 .env.local 并填入实际值：
#   cp .env.local.example .env.local

# --- 当前活跃链 ---
# 管理后台默认操作的链 ID
# 80069 = Bepolia 测试网, 80094 = Berachain 主网, 42161 = Arbitrum, 1 = Ethereum
NEXT_PUBLIC_CHAIN_ID=80094

# --- Berachain 主网 ---
NEXT_PUBLIC_BERACHAIN_RPC=https://rpc.berachain.com
NEXT_PUBLIC_BERACHAIN_CONTRACT=0x
NEXT_PUBLIC_BERACHAIN_PAYMENT_TOKEN=0x
# USDT0 合约地址

# --- Bepolia 测试网 ---
NEXT_PUBLIC_BEPOLIA_RPC=https://bepolia.rpc.berachain.com
NEXT_PUBLIC_BEPOLIA_CONTRACT=0x
NEXT_PUBLIC_BEPOLIA_PAYMENT_TOKEN=0x

# --- Arbitrum ---
NEXT_PUBLIC_ARBITRUM_RPC=https://arb1.arbitrum.io/rpc
NEXT_PUBLIC_ARBITRUM_CONTRACT=0x
NEXT_PUBLIC_ARBITRUM_PAYMENT_TOKEN=0x
# USDT 合约地址

# --- Ethereum ---
NEXT_PUBLIC_ETHEREUM_RPC=https://eth.llamarpc.com
NEXT_PUBLIC_ETHEREUM_CONTRACT=0x
NEXT_PUBLIC_ETHEREUM_PAYMENT_TOKEN=0x
# USDT 合约地址

# --- 管理员配置 ---
# 管理员钱包地址白名单（逗号分隔）
NEXT_PUBLIC_ADMIN_WALLETS=0x

# --- 服务端配置（不暴露到前端）---
# 管理员私钥，用于链上操作（黑名单传播、资金管理等）
# ⚠️ 绝对不要提交到代码仓库
ADMIN_PRIVATE_KEY=
