generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -- Indexer State --
model IndexerState {
  id                 Int      @id @default(1)
  lastProcessedBlock Int
  updatedAt          DateTime @updatedAt
  @@map("indexer_state")
}

// -- Event Tables --
model Transfer {
  id          Int      @id @default(autoincrement())
  txHash      String   @map("tx_hash")
  logIndex    Int      @map("log_index")
  blockNumber Int      @map("block_number")
  operator    String
  from        String
  to          String
  tokenId     String   @map("token_id")
  amount      String
  isBatch     Boolean  @default(false) @map("is_batch")
  timestamp   DateTime @default(now())
  @@unique([txHash, logIndex], name: "txHash_logIndex")
  @@index([from])
  @@index([to])
  @@index([tokenId])
  @@index([blockNumber])
  @@map("transfers")
}

model Purchase {
  id               Int      @id @default(autoincrement())
  txHash           String   @map("tx_hash")
  logIndex         Int      @map("log_index")
  blockNumber      Int      @map("block_number")
  buyer            String
  seller           String
  tokenId          String   @map("token_id")
  price            Decimal  @db.Decimal(78, 0)
  amount           String
  commissionAmount Decimal  @map("commission_amount") @db.Decimal(78, 0)
  timestamp        DateTime @default(now())
  @@unique([txHash, logIndex], name: "txHash_logIndex")
  @@index([buyer])
  @@index([seller])
  @@index([tokenId])
  @@index([blockNumber])
  @@map("purchases")
}

model BlacklistUpdate {
  id             Int      @id @default(autoincrement())
  txHash         String   @map("tx_hash")
  logIndex       Int      @map("log_index")
  blockNumber    Int      @map("block_number")
  entityType     Int      @map("entity_type")
  entityId       String   @map("entity_id")
  entityAddress  String   @map("entity_address")
  isBlacklisted  Boolean  @map("is_blacklisted")
  timestamp      DateTime @default(now())
  @@unique([txHash, logIndex], name: "txHash_logIndex")
  @@index([entityAddress])
  @@index([entityId])
  @@map("blacklist_updates")
}

model CollectionCreated {
  id           Int      @id @default(autoincrement())
  txHash       String   @map("tx_hash")
  logIndex     Int      @map("log_index")
  blockNumber  Int      @map("block_number")
  creator      String
  collectionId String   @map("collection_id")
  metadataURI  String   @map("metadata_uri")
  timestamp    DateTime @default(now())
  @@unique([txHash, logIndex], name: "txHash_logIndex")
  @@index([creator])
  @@index([collectionId])
  @@map("collections_created")
}

model CommissionClaimed {
  id          Int      @id @default(autoincrement())
  txHash      String   @map("tx_hash")
  logIndex    Int      @map("log_index")
  blockNumber Int      @map("block_number")
  claimant    String
  amount      Decimal  @db.Decimal(78, 0)
  timestamp   DateTime @default(now())
  @@unique([txHash, logIndex], name: "txHash_logIndex")
  @@index([claimant])
  @@map("commissions_claimed")
}

model TokenBalance {
  id       Int    @id @default(autoincrement())
  address  String
  tokenId  String @map("token_id")
  balance  String
  @@unique([address, tokenId], name: "address_tokenId")
  @@index([address])
  @@index([tokenId])
  @@map("token_balances")
}

model StorefrontConfig {
  id           Int       @id @default(autoincrement())
  collectionId String    @unique @map("collection_id")
  seller       String
  title        String?
  description  String?   @db.Text
  bannerImage  String?   @map("banner_image")
  saleStart    DateTime? @map("sale_start")
  saleEnd      DateTime? @map("sale_end")
  isActive     Boolean   @default(true) @map("is_active")
  createdAt    DateTime  @default(now()) @map("created_at")
  updatedAt    DateTime  @updatedAt @map("updated_at")
  @@index([seller])
  @@map("storefront_configs")
}

model Distributor {
  id             Int      @id @default(autoincrement())
  address        String
  referrerAddr   String?  @map("referrer_address")
  collectionId   String   @map("collection_id")
  tier           Int
  totalEarned    Decimal  @default(0) @map("total_earned") @db.Decimal(78, 0)
  createdAt      DateTime @default(now()) @map("created_at")
  @@unique([address, collectionId], name: "address_collectionId")
  @@index([referrerAddr])
  @@index([collectionId])
  @@map("distributors")
}

model DistributionConfig {
  id           Int      @id @default(autoincrement())
  collectionId String   @unique @map("collection_id")
  tierBps      Int[]    @map("tier_bps")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  @@map("distribution_configs")
}

model CommissionEarning {
  id           Int      @id @default(autoincrement())
  txHash       String   @map("tx_hash")
  logIndex     Int      @map("log_index")
  blockNumber  Int      @map("block_number")
  distributor  String
  collectionId String   @map("collection_id")
  tokenId      String   @map("token_id")
  amount       Decimal  @db.Decimal(78, 0)
  tier         Int
  timestamp    DateTime @default(now())
  @@unique([txHash, logIndex], name: "txHash_logIndex")
  @@index([distributor])
  @@index([tokenId])
  @@index([collectionId])
  @@map("commission_earnings")
}

model BlacklistFlag {
  id              Int       @id @default(autoincrement())
  transferId      Int       @unique @map("transfer_id")
  tokenId         String    @map("token_id")
  fromAddress     String    @map("from_address")
  toAddress       String    @map("to_address")
  detectedPrice   Decimal?  @map("detected_price") @db.Decimal(78, 0)
  originalPrice   Decimal   @map("original_price") @db.Decimal(78, 0)
  reason          String
  status          String    @default("pending")
  reviewedAt      DateTime? @map("reviewed_at")
  reviewedBy      String?   @map("reviewed_by")
  createdAt       DateTime  @default(now()) @map("created_at")
  @@index([status])
  @@index([tokenId])
  @@map("blacklist_flags")
}

model DetectionState {
  id                 Int @id @default(1)
  lastCheckedBlock   Int @map("last_checked_block")
  @@map("detection_state")
}

model ShortLink {
  id           Int      @id @default(autoincrement())
  code         String   @unique @db.VarChar(8)
  collectionId String   @map("collection_id")
  address      String
  refToken     String   @map("ref_token")
  clicks       Int      @default(0)
  createdAt    DateTime @default(now()) @map("created_at")
  @@index([address, collectionId])
  @@map("short_links")
}

// -- Admin Audit Log (new table for admin panel) --
model AdminAuditLog {
  id          Int      @id @default(autoincrement())
  adminAddr   String   @map("admin_address")
  action      String
  target      String
  details     String?  @db.Text
  txHash      String?  @map("tx_hash")
  createdAt   DateTime @default(now()) @map("created_at")
  @@index([adminAddr])
  @@index([action])
  @@index([createdAt])
  @@map("admin_audit_logs")
}
